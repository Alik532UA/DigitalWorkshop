		"@types/node": "^25.6.0",
		"eslint": "^10.2.1",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.1",
